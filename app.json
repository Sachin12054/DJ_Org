{
  "expo": {
    "name": "Rix",
    "slug": "dj-event-manager",
    "scheme": "djmanager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0D0B14",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0B14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dj.eventmanager"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0B14"
      },
      "package": "com.dj.eventmanager",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#E94560"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "3be2c047-7504-403f-bd13-0a508606b09e"
      }
    },
    "owner": "kishore_sachin"
  }
}
