# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Firebase Admin SDK service account keys (SERVER ONLY — never commit!)
*-firebase-adminsdk-*.json
google-services.json
GoogleService-Info.plist

# Environment variables
.env
.env.*

# Windows reserved filename that can break git add on Windows
nul
